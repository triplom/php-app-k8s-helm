# Copy this file to .env and fill in real credentials.
# The .env file is listed in .gitignore and must never be committed to version control.

# MariaDB credentials (used by docker-compose)
MARIADB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MARIADB_USER=appuser
MARIADB_PASSWORD=CHANGE_ME_APP_PASSWORD
MARIADB_DATABASE=appdb

# Application version (optional — defaults to 0.2.2)
APP_VERSION=0.2.2
